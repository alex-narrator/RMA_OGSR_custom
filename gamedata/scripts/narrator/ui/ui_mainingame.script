function MainIngameOverlay:UpdateActiveItem()
	local act_item = actor:active_item()
	local weapon = act_item and get_clsid(act_item) ~= clsid.wpn_binocular_s and act_item:get_weapon_m()
	self.active_item:Show(weapon and SHOW_ACTIVE_ITEM_INFO)

	if not self.active_item:IsShown() then
	return end

	self.active_item.icon:DetachAll()
	
	local ammo_count = act_item:get_ammo_in_magazine()
	local ammo_sect = self.active_item.ammo_sect or get_cur_ammo_sect(act_item)

	local ammo_icon = ui_cell_item.UICellItemSimple(self.active_item.icon, ammo_sect)
	local offset = ui_inv_utils.GetOffset("center", ammo_icon, self.active_item.icon)
	ammo_icon:SetWndPos(offset.x, offset.y)
	
	local switch_mode = not not self.active_item.ammo_sect
	
	self.active_item.ammo_counter:Show(not switch_mode)
	self.active_item.ammo_name:Show(not switch_mode)
	self.active_item.fire_mode:Show(not switch_mode)
	self.active_item.switch_ammo_name:Show(switch_mode)
	
	if self.active_item.ammo_sect then
		local text = string.format("%s:\\n%s", game.translate_string("st_next_ammo_type"), get_inv_name_short(ammo_sect))
		self.active_item.switch_ammo_name:SetText(text)
	else
		self.active_item.ammo_counter:SetText(string.format("[%s]", ammo_count))
		local text = ammo_count > 0 and game.translate_string(read_if_exists(sys_ini, "string", ammo_sect, "inv_name_short", get_inv_name(ammo_sect))) or ""
		self.active_item.ammo_name:SetText(text)
	
		ammo_icon:Show(ammo_count > 0)
	
		local text = ""
		if act_item:get_gl_mode() then
			text = string.format("%s[%s] ", "%c[UI_orange]", get_fire_mode_str(act_item))
		elseif has_fire_modes(act_item) then
			local f_mod_tbl = get_fire_modes(act_item)
			local cur_f_mode = weapon.cur_fire_mode
			for k,v in pairs(f_mod_tbl) do
				local val = v == -1 and "A" or v
				if tonumber(k) == cur_f_mode + 1 then
					text = text..string.format("%s[%s] ", "%c[UI_orange]", val)
				else
					text = text..string.format("%s%s ", "%c[default]", val)
				end
			end
		end
		self.active_item.fire_mode:SetText(text)	
	end
end

