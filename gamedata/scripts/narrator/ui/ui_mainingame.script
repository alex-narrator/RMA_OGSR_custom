function MainIngameOverlay:UpdateConditions()
	for k,v in pairs(self.conditions) do
		v.bar:SetProgressPos(v.condition())
		v.back:Show(v.condition() <= v.show_val or not DYNAMIC_SHOW)
		--log3("cond %s val %s", k, v.condition())
	end
	
	for k,v in pairs(self.conditions_circles) do
		v.progress_shape:SetPos(v.condition())
		local show = v.condition() <= v.show_val or not DYNAMIC_SHOW
		v.progress_shape:Show(show)
		v.back:Show(show)
		v.icon:Show(show)
	end
	
	for k,v in pairs(self.conditions_icons) do
		local idx = 1
		for kk,vv in ipairs(v.thresholds) do
			if v.condition() >= vv then
				idx = kk
			end
		end
		v.icon:InitTexture(v.texture_name..idx)
	end
	
	self:UpdateBloodOverlay()
end

function MainIngameOverlay:UpdateBloodOverlay()
	local max_alpha = 1 - actor.health
	local target_val = max_alpha
	if self.blood_overlay.fade_time > 0 then
		if self.blood_cur_alpha == nil then
			self.blood_cur_alpha = 0
		end	
		local change_part = target_val / self.blood_overlay.fade_time * level.get_time_factor()
		local conds = actor_obj.condition
		local f_dt = conds:fdelta_time() * 0.01
		--log3("~f_dt %s", f_dt)
		
		if self.dec_alpha then
			change_part = -change_part
		end
		
		--log3("~change_part %s", change_part)
		
		self.blood_cur_alpha = self.blood_cur_alpha + f_dt * change_part
		
		if self.blood_cur_alpha <= 0 then
			self.dec_alpha = false
		elseif self.blood_cur_alpha >= target_val then
			self.dec_alpha = true
		end
		self.blood_cur_alpha = math.clamp(self.blood_cur_alpha, 0, target_val)
	else
		self.blood_cur_alpha = max_alpha
	end
	--log3("~alpha %s", self.blood_cur_alpha)
	self.blood_overlay:SetColorA(255 * self.blood_cur_alpha)
end

function MainIngameOverlay:UpdateMotionIcon()
	--self.motion_icon:Show(not actor:get_holder())
	local state = "normal"
	if actor_obj:is_actor_climb() or actor_obj:is_actor_climbing() then
		state = "climb"
	elseif actor_obj:is_actor_crouch() or actor_obj:is_actor_crouching() then
		state = "crouch"
	elseif actor_obj:is_actor_creep() or actor_obj:is_actor_creeping() then
		state = "creep"
	elseif actor_obj:is_actor_sprinting() then
		state = "sprint"		
	elseif (actor_obj:is_actor_moving() and not actor_obj:is_actor_running()) or actor_obj:is_zoom_aiming_mode() then
		state = "run"
	end
	local texture = MOTION_TEXTURE_PREFIX..state
	if self.current_motion_texture ~= texture then
		self.motion_icon.icon:InitTexture(texture)
		self.current_motion_texture = texture
		--log3("~current state %s", state)
	end
end

function MainIngameOverlay:TryUpdatePanelItems(item, prev_place)
	if prev_place == inv_place.belt or quick_slots.is_in_quick_slot(item) then 
		self:SetPanelItemsNeedUpdate()
	end
end

function MainIngameOverlay:OnItemUse(item)
	local ci = self:GetEquipedCellItem(item)
	if ci then
		ci:ForceUpdate()
	end
end

function MainIngameOverlay:SetPanelItemsNeedUpdate()
	self.update_panel_items = true
end

function MainIngameOverlay:UpdatePanelItems()
	if level.is_removing_objects() then
	return end
	
	self.equiped_panel:Show(SHOW_GEAR_INFO)
	
	if not self.update_panel_items then
	return end
	self.update_panel_items = false
	
	local items = {}
	for i = 0, actor:belt_count() - 1 do
		item = actor:item_on_belt(i)
		if item and not loadout.is_module(item) then
			--items[item:id()] = item
			table.insert(items, item)
		end
	end
	for k,v in pairs(loadout.get_loaded_items()) do
		item = level.object_by_id(k)
		if item then
			-- items[item:id()] = item
			table.insert(items, item)
		end
	end
	table.sort(items,ui_inv_utils.sort_by_quick_slot_num)
	self.equiped_panel:DetachAll()
	self.equiped_panel.cell_items = {}
	local function add_similar(item)
		if not self.equiped_panel.group_similar then
		return false end
		for id, cell_item in pairs(self.equiped_panel.cell_items) do
			if ui_inv_utils.similar_item(cell_item:GetItem(), item) then
				cell_item:AddChild(item)
				return true
			end
		end
		return false
	end
	local pos = vector2()
	local cell_size = self.equiped_panel.cell_size
	local final_size = vector2()
	local indent = self.equiped_panel.indent
	local vertical = self.equiped_panel.vertical
	for _, item in pairs(items) do
		if not add_similar(item) then
			local cell_item = ui_cell_item.UICellItem(self.equiped_panel, item, cell_size)
			cell_item:SetWndPos(pos.x, pos.y)
			self.equiped_panel.cell_items[item:id()] = cell_item
			if vertical then
				pos.y = pos.y + cell_item:GetHeight() + indent
				final_size.y = pos.y
				local width = cell_item:GetWidth()
				if width > final_size.x then
					final_size.x = width
				end
			else
				pos.x = pos.x + cell_item:GetWidth() + indent
				final_size.x = pos.x
				local height = cell_item:GetHeight()
				if height > final_size.y then
					final_size.y = height
				end
			end
			local quick_num = quick_slots.get_slot_num(item)
			if quick_num then
				local text = game.translate_string("ui_quick_slot_"..quick_num)
				local quick_key = self.xml:InitStatic("equiped_panel:quick_key", cell_item)
				quick_key:SetText(text)
				quick_key:AdjustHeightToText()
				quick_key:AdjustWidthToText()
				local offset = ui_inv_utils.GetOffset(self.equiped_panel.quick_key_offset, quick_key, cell_item)
				quick_key:SetWndPos(offset.x, offset.y)
				cell_item.quick_key = quick_key				
			end
		end
	end
	self.equiped_panel:SetHeight(final_size.y)
	self.equiped_panel:SetWidth(final_size.x)
	local offset = ui_inv_utils.GetOffset(self.equiped_panel.offset_type, self.equiped_panel, self.owner)
	local оfset_shift = self.equiped_panel.offset_shift
	self.equiped_panel:SetWndPos(offset.x + оfset_shift.x, offset.y + оfset_shift.y)
end

function MainIngameOverlay:GetEquipedCellItem(item)
	for id, cell_item in pairs(self.equiped_panel.cell_items) do
		if cell_item:IsChild(item) then
			return cell_item
		end
		if id == item:id() then
			return cell_item
		end
	end
	return nil
end

