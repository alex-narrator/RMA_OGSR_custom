local addon_params = {
		{name = "bullet_hit_power_k", 			unit = "%", default = 0, invert = false},
		{name = "bullet_speed_k", 				unit = "%", default = 0, invert = false},
		{name = "fire_dispersion_base_k", 		unit = "%", default = 0, invert = true},
		{name = "cam_dispersion_k", 			unit = "%", default = 0, invert = true},
		{name = "condition_shot_dec_silencer", 	unit = "%", default = 0, invert = true},
		{name = "zoom_rotate_time_k", 			unit = "%", default = 0, invert = false, multiplier = -1},
	}
function UIItemInfo:AttachAddonParams()
	local show = false
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(addon_params, "st_addon_header", params_list)
	
	local sect = self.item:section()
	local val, text, color
	for k,v in ipairs(addon_params) do
		val = read_if_exists(sys_ini, "float", sect, v.name, v.default)
		if val ~= v.default then
			v.static = CUIStatic()
			v.static:SetTextComplexMode(true)
			v.static:SetWidth(params_list:GetDesiredChildWidth())
			if v.unit == "%" then
				val = val * 100
			end
			if v.multiplier then
				val = val * v.multiplier
			end
			color = (val > 0 ) and "%c[green]" or "%c[red]"
			if v.invert then
				color = val > 0 and "%c[red]" or "%c[green]"
			end			
			text = string.format(v.is_int and "%s %s %s%.0f %s" or "%s %s %s%+.1f %s", game.translate_string("st_list_mark"), game.translate_string("ui_st_"..v.name), color, val, game.translate_string(v.unit))
			v.static:SetText(text)
			v.static:AdjustHeightToText()
			show = true
			params_list:AddWindow(v.static)
		end
	end
	params_list:SetHeight(params_list:GetPadSize().y)
	if not show then
		params_list:Show(false)
	end
	return show
end

------------------------------------------VEST ARMOR PLATE WND-----------------------------------------------------------------------------------------------------------------
function UIItemInfo:AttachPlateCondition()
	local bind_item = self.item:binded_object()
	
	local plate_params = self.xml:InitStatic("plate_params", self.descr_list)
	
	local cap_plate = self.xml:InitStatic("plate_params:cap_plate", plate_params)
	local text = string.format("%s:\\n%s", game.translate_string("st_attached_plate"), get_inv_name_short(bind_item:get_plate_sect()))
	cap_plate:SetTextComplexMode(true)
	cap_plate:SetText(text)
	
	local condition_progress = self.xml:InitProgressBar("plate_params:progress_condition", plate_params)
	condition_progress:SetProgressPos(bind_item:get_plate_condition())
	return true
end

------------------------------------------COMPATIBLE ARMOR PLATES WND-----------------------------------------------------------------------------------------------------------------
local plates = {}
function UIItemInfo:AttachArmorPlates()
	if not self.item:binded_object() then
	return end

	plates = self.item:binded_object():get_plates()

	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(plates, "st_compatible_plate", params_list)

	local text
	for k,v in pairs(plates) do
		v.st = CUIStatic()
		local _st = v.st
		_st:SetWidth(params_list:GetDesiredChildWidth())
		text = string.format("%s %s", game.translate_string("st_list_mark"), get_inv_name(v.section))
		_st:SetText(text)
		_st:SetTextComplexMode(true)
		-- _st:SetTextColor(params_list.text_color)
		-- _st:SetFont(GetFontCustom(params_list.font))
		_st:AdjustHeightToText()
		params_list:AddWindow(_st)
	end
	params_list:SetHeight(params_list:GetPadSize().y)
	return true
end

-----------------------------------------------------BELT SLOTS PARAMS-----------------------------------------------------------------------------------------------------------
local belt_slots_st
function UIItemInfo:AttachBeltParams()
	local belt_size = read_if_exists(sys_ini, "u32", self.item:section(), "belt_size", 0)
	if belt_size <= 0 then return end
	
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)

	belt_slots_st = CUIStatic()
	belt_slots_st:SetTextComplexMode(true)
	belt_slots_st:SetWidth(params_list:GetDesiredChildWidth())
	local color = "%c[UI_orange]"
	local text = string.format("%s %s %s%s", game.translate_string("st_list_mark"), game.translate_string("ui_st_belt_slots"), color, belt_size)
	belt_slots_st:SetText(text)
	belt_slots_st:AdjustHeightToText()
	params_list:AddWindow(belt_slots_st)
	params_list:SetHeight(params_list:GetPadSize().y)
	return true
end


-----------------------------------------------------PDA OWNER INFO------------------------------------------------------------------------------------------------------------------------
local ui_owner_data = {}
function UIItemInfo:AttachPDAOwnerInfo()
	local se_item = alife():object(self.item:id())
	
	local owner_data = se_item.owner_data
	if not owner_data then
	return end
	
	if owner_data.name == "" then
	return end
	
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(ui_owner_data, "st_pda_owner", params_list)

	local color = "%c[UI_orange]"
	
	local name_st = CUIStatic()
	ui_owner_data.name_st = name_st
	name_st:SetTextComplexMode(true)
	name_st:SetWidth(params_list:GetDesiredChildWidth())
	local text = string.format("%s %s: %s%s", game.translate_string("st_list_mark"), game.translate_string("ui_st_name"), color, game.translate_string(owner_data.name))
	name_st:SetText(text)
	name_st:AdjustHeightToText()
	params_list:AddWindow(name_st)
	
	local comm_st = CUIStatic()
	ui_owner_data.comm_st = comm_st
	comm_st:SetTextComplexMode(true)
	comm_st:SetWidth(params_list:GetDesiredChildWidth())
	text = string.format("%s %s: %s%s", game.translate_string("st_list_mark"), game.translate_string("ui_st_community"), color, game.translate_string(owner_data.comm))
	comm_st:SetText(text)
	comm_st:AdjustHeightToText()
	params_list:AddWindow(comm_st)
	
	local rank_st = CUIStatic()
	ui_owner_data.rank_st = rank_st
	rank_st:SetTextComplexMode(true)
	rank_st:SetWidth(params_list:GetDesiredChildWidth())
	text = string.format("%s %s: %s%s", game.translate_string("st_list_mark"), game.translate_string("ui_st_rank"), color, game.translate_string(ranks.get_val_rank_name(owner_data.rank)))
	rank_st:SetText(text)
	rank_st:AdjustHeightToText()
	params_list:AddWindow(rank_st)
	
	local lock_st = CUIStatic()
	ui_owner_data.lock_st = lock_st
	local lock_text = ""
	if se_item.lock_state == 0 then
		lock_text = "ui_st_unlocked"
		color = "%c[green]"
	elseif se_item.lock_state == 1 then
		lock_text = "ui_st_locked"
		color = "%c[UI_orange]"
	elseif se_item.lock_state == 2 then
		lock_text = "ui_st_dead_locked"
		color = "%c[red]"
	end
	lock_st:SetTextComplexMode(true)
	lock_st:SetWidth(params_list:GetDesiredChildWidth())
	text = string.format("%s %s: %s%s", game.translate_string("st_list_mark"), game.translate_string("ui_st_lock_state"), color, game.translate_string(lock_text))
	lock_st:SetText(text)
	lock_st:AdjustHeightToText()
	params_list:AddWindow(lock_st)	
	
	params_list:SetHeight(params_list:GetPadSize().y)
	return true
end

-----------------------------------------------------REPAIR PARAMS-----------------------------------------------------------------------------------------------------------
local repair_params = {
		--//service
		{name = "service_type", 			prefix="", unit = "", default = "", _type = "string"},
		{name = "service_cond_threshold", 		prefix="", unit = "%", default = 0, _type = "float"},
		{name = "service_condition_gain", 	prefix="", unit = "%", default = 0, _type = "float"},
		--//repair
		{name = "repair_type", 				prefix="", unit = "", default = "", _type = "string"},
		{name = "repair_bonus", 			prefix="x", unit = "", default = 0, _type = "float"},
	}
function UIItemInfo:AttachRepairParams()
	local sect = self.item:section()
	if read_if_exists(sys_ini, "float", sect, "service_condition_gain", 0) <= 0 and read_if_exists(sys_ini, "float", sect, "repair_bonus", 0) <= 0 then
	return end
	
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(repair_params, "st_repair_header", params_list)
	
	for k,v in ipairs(repair_params) do
		local val = read_if_exists(sys_ini, v._type, sect, v.name, v.default)
		if val ~= v.default then
			val = v._type == "string" and game.translate_string("st_repair_"..val) or math.round(val, 2)
			if v.unit == "%" then
				val = val * 100
			end
			v.static = CUIStatic()
			v.static:SetTextComplexMode(true)
			v.static:SetWidth(params_list:GetDesiredChildWidth())
			local color = "%c[UI_orange]"
			local text = string.format("%s %s: %s%s%s%s", game.translate_string("st_list_mark"), game.translate_string("st_"..v.name), color, v.prefix, val, v.unit)
			v.static:SetText(text)
			v.static:AdjustHeightToText()
			params_list:AddWindow(v.static)
			params_list:SetHeight(params_list:GetPadSize().y)
		end
	end
	return true
end

-----------------------------------------------------LOOT SPAWN BOX PARAMS-----------------------------------------------------------------------------------------------------------
local loot_spawn_box_st = {}
function UIItemInfo:AttachLootSpawnBoxInfo()
	local sect = self.item:section()
	local items_str = loot_spawn_box.get_spawn_items(sect)
	if not items_str then
	return end
	
	loot_spawn_box_st = {}	
	
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(loot_spawn_box_st, "st_loot_spawn_box_header", params_list)
	
	local spawn_items = parse_key_val_line(items_str, 1)
	
	for section,count in pairs(spawn_items) do
		local static = CUIStatic()
		static = CUIStatic()
		static:SetTextComplexMode(true)
		static:SetWidth(params_list:GetDesiredChildWidth())
		local text = string.format("%s%s %s", game.translate_string("st_list_mark"), get_inv_name(section), count > 1 and "x"..count or "")
		static:SetText(text)
		static:AdjustHeightToText()
		
		loot_spawn_box_st[section] = static
		params_list:AddWindow(static)
	end
	params_list:SetHeight(params_list:GetPadSize().y)
	return true
end

-------------------------------------------------QUEST TARGET INFO-----------------------------------------------------------------------------------------------------------------------
function UIItemInfo:AttachQuestTargetInfo()
	local sect = self.item:section()
	local quest_name = task_manager.item_for_quest(sect) or read_if_exists(sys_ini, "string", sect, "item_for_quest", nil)
	if quest_name then
		local item_for_quest = self.xml:InitStatic("item_for_quest", self.descr_list)
		item_for_quest:SetWidth(self.descr_list:GetDesiredChildWidth())
		local text = string.format("%s:\\n%s", game.translate_string("st_item_for_quest"), game.translate_string(quest_name))
		item_for_quest:SetTextComplexMode(true)
		item_for_quest:SetText(text)
		item_for_quest:AdjustHeightToText()
		local info_icon = self.xml:InitStatic("item_for_quest:info_icon", item_for_quest)
	end
	return not not quest_name
end