local addon_params = {
		{name = "bullet_hit_power_k", 			unit = "%", default = 0, invert = false},
		{name = "bullet_speed_k", 				unit = "%", default = 0, invert = false},
		{name = "fire_dispersion_base_k", 		unit = "%", default = 0, invert = true},
		{name = "cam_dispersion_k", 			unit = "%", default = 0, invert = true},
		{name = "condition_shot_dec_silencer", 	unit = "%", default = 0, invert = true},
		{name = "zoom_rotate_time_k", 			unit = "%", default = 0, invert = false, multiplier = -1},
	}
function UIItemInfo:AttachAddonParams()
	local show = false
	local params_list = self:AttachParamsList()
	self:AttachHeader("st_addon_header", params_list)
	
	local sect = self.item:section()
	for k,v in ipairs(addon_params) do
		local val = read_if_exists(sys_ini, "float", sect, v.name, v.default)
		if val ~= v.default then
			if v.unit == "%" then
				val = val * 100
			end
			if v.multiplier then
				val = val * v.multiplier
			end
			local color = (val > 0 ) and green or red
			if v.invert then
				color = val > 0 and red or green
			end			
			local text = string.format(v.is_int and "%.0f %s" or "%+.1f %s", val, game.translate_string(v.unit))
			
			local static = self:AttachParamItem(params_list)
			static.icon:InitTexture(v.texture or "")
			static.icon:SetColor(green)
			static:SetText(game.translate_string("ui_st_"..v.name))
			static:SetTextPos(0,0)
			static.val:SetText(text)
			static.val:SetTextColor(color)
			
			show = true
		end
	end
	self:AdjustParamsList(params_list)
	if not show then
		params_list:Show(false)
	end
	return show
end

