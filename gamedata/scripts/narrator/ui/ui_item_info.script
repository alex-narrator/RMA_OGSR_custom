-----------------------------------------------------PDA OWNER INFO------------------------------------------------------------------------------------------------------------------------
function UIItemInfo:AttachPDAOwnerInfo()
	local se_item = alife():object(self.item:id())
	
	local owner_data = se_item.owner_data
	if not owner_data then
	return end
	
	if owner_data.name == "" then
	return end
	
	local params_list = self:AttachParamsList()
	self:AttachHeader("st_pda_owner", params_list)

	local color = orange
	
	local static = self:AttachParamItem(params_list)
	static:SetWidth(params_list:GetDesiredChildWidth())
	static:SetText(game.translate_string(owner_data.name))
	static.icon:InitTexture("ui_hud_icon_personal_id")
	static.icon:SetColor(color)
	
	local static = self:AttachParamItem(params_list)
	static:SetText(game.translate_string(owner_data.comm))
	static.icon:InitTexture(community.get_icon_sect(owner_data.comm))
	
	local static = self:AttachParamItem(params_list)
	static:SetText(game.translate_string(ranks.get_val_rank_name(owner_data.rank)))
	static.icon:InitTexture(ranks.get_icon_sect(owner_data.rank))
	
	local static = self:AttachParamItem(params_list)
	local lock_text = ""
	if se_item.lock_state == 0 then
		lock_text = "ui_st_unlocked"
		color = green
	elseif se_item.lock_state == 1 then
		lock_text = "ui_st_locked"
		color = orange
	elseif se_item.lock_state == 2 then
		lock_text = "ui_st_dead_locked"
		color = red
	end
	static:SetText(game.translate_string(lock_text))
	static:SetTextColor(color)
	static.icon:InitTexture("ui_hud_icon_lock")
	static.icon:SetColor(color)
	
	self:AdjustParamsList(params_list)
	return true
end

-----------------------------------------------------REPAIR PARAMS-----------------------------------------------------------------------------------------------------------
local repair_params = {
		--//service
		{name = "service_type", 			prefix="", unit = "", 	default = "", 	_type = "string"},
		{name = "service_cond_threshold", 	prefix="", unit = "%", 	default = 0, 	_type = "float"},
		{name = "service_condition_gain", 	prefix="", unit = "%", 	default = 0, 	_type = "float"},
		--//repair
		{name = "repair_type", 				prefix="", unit = "", 	default = "", 	_type = "string"},
		{name = "repair_bonus", 			prefix="x", unit = "", 	default = 0, 	_type = "float"},
	}
function UIItemInfo:AttachRepairParams()
	local sect = self.item:section()
	if read_if_exists(sys_ini, "float", sect, "service_condition_gain", 0) <= 0 and read_if_exists(sys_ini, "float", sect, "repair_bonus", 0) <= 0 then
	return end
	
	local params_list = self:AttachParamsList()
	self:AttachHeader("st_repair_header", params_list)
	
	for k,v in ipairs(repair_params) do
		local val = read_if_exists(sys_ini, v._type, sect, v.name, v.default)
		if val ~= v.default then
			val = v._type == "string" and game.translate_string("st_repair_"..val) or math.round(val, 2)
			if v.unit == "%" then
				val = val * 100
			end
			local color = orange
			local text = string.format("%s%s%s", v.prefix, val, v.unit)
			local static = self:AttachParamItem(params_list)
			static:SetText(game.translate_string("st_"..v.name))
			static:SetTextPos(0, 0)
			static.val:SetText(text)
			static.val:SetWidth(100)
			static.val:SetTextColor(color)
		end
	end
	self:AdjustParamsList(params_list)
	return true
end

-----------------------------------------------------LOOT SPAWN BOX PARAMS-----------------------------------------------------------------------------------------------------------
function UIItemInfo:AttachLootSpawnBoxInfo()
	local sect = self.item:section()
	local items_str = loot_spawn_box.get_spawn_items(sect)
	if not items_str then
	return end
	
	local params_list = self:AttachParamsList()
	self:AttachHeader("st_loot_spawn_box_header", params_list)
	
	local spawn_items = parse_key_val_line(items_str, 1)
	
	for section,count in pairs(spawn_items) do
		local text = count > 1 and string.format("x%s %s", count, get_inv_name(section)) or get_inv_name(section)
		local static = self:AttachParamItem(params_list)
		static:SetTextPos(0, 0)
		static:SetText(text)
	end
	self:AdjustParamsList(params_list)
	return true
end

-------------------------------------------------QUEST TARGET INFO-----------------------------------------------------------------------------------------------------------------------
function UIItemInfo:AttachQuestTargetInfo()
	local sect = self.item:section()
	local quest_name = task_manager.item_for_quest(sect) or read_if_exists(sys_ini, "string", sect, "item_for_quest", nil)
	if quest_name then
		local item_for_quest = self.xml:InitStatic("item_for_quest", self.info_list)
		item_for_quest:SetWidth(self.dcw)
		local text = string.format("%s:\\n%s", game.translate_string("st_item_for_quest"), game.translate_string(quest_name))
		item_for_quest:SetTextComplexMode(true)
		item_for_quest:SetText(text)
		item_for_quest:AdjustHeightToText()
		local info_icon = self.xml:InitStatic("item_for_quest:info_icon", item_for_quest)
	end
	return not not quest_name
end