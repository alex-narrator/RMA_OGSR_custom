-- -*- mode: lua; coding: windows-1251-dos -*-
function attach(sm)
	sm:subscribe({signal = "on_cell_item_focus", 		fun = this.on_focus})
	sm:subscribe({signal = "on_quick_item_focus", 		fun = this.on_quick_focus})
end

local green = GetARGB(255, 0, 255, 0)
local red = GetARGB(255, 255, 0, 0)
local orange = GetARGB(255, 238, 153, 26)
local default = GetARGB(255, 255, 255, 255)

local plus_are_bad = {
	["radiation_restore_speed"] = true,
	["alcohol_restore_speed"] = true,
	["boost_somnolence"] = true,
	["boost_pain"] = true,
	["power_loss"] = true,
}

local plus_are_bad_eatable = {
	["radiation"] = true,
	["alcohol"] = true,
	["somnolence"] = true,
}

local OVERLAY_XML = "script_overlays\\ui_item_info.xml"

function on_focus(item)
	if not get_script_option_value("floating_info") then
	return end
	UIItemInfo(item)
end

function on_quick_focus(slot_num, sect, item)
	if not get_script_option_value("floating_info") or not item then
	return end
	UIItemInfo(item)
end

------------------------------------------MAIN ITEM INFO WINDOW-----------------------------------------------------------------------------------------------------------------

class "UIItemInfo" (CUIScriptWnd)
function UIItemInfo:__init(item, independent) super()
	self.owner = level.main_input_receiver()
	self.item = item
	self.independent = independent
	self:InitControls()
	self:Subscribe()
	self:SetShowTime()
	self:SetAutoDelete(true)
end

function UIItemInfo:__finalize()
	--log_news("UIItemInfo:__finalize()")
end

function UIItemInfo:Subscribe()
	if not self.subscribed then
		self.subscribed = {
			{signal = "on_cell_item_focus_lost", self = self, fun = self.DetachWnd},
			{signal = "on_quick_item_focus_lost", self = self, fun = self.DetachWnd},
		}
		local sm = ogsr_signals.get_mgr()
		for _, s in ipairs( self.subscribed ) do
			sm:subscribe( s )
		end
	end
end

function UIItemInfo:Unsubscribe()
	if self.subscribed then
		local sm = ogsr_signals.get_mgr()
		for _, s in ipairs( self.subscribed ) do
			sm:unsubscribe( s )
		end
		self.subscribed = false
	end
end

function UIItemInfo:DetachWnd()
	if self.independent then
		level.start_stop_menu(self, false)
	else	
		self.owner:DetachChild(self)
	end
	self:ClearCallbacks()
	self:Unsubscribe()
end

function UIItemInfo:InitControls()
	self:Init(0, 0, UI_BASE_WIDTH, UI_BASE_HEIGHT)
	if self.independent then
		level.start_stop_menu(self, false)
	else
		self.owner:AttachChild(self)
		self:Show(true)
	end

	self.xml = CScriptXmlInit()
	self.xml:ParseFile(OVERLAY_XML)
	
	self.background_contrast = self.xml:InitStatic("background_contrast", self)
	self.background_contrast:Show(false)

	local root = "background_frame"
	self.background_frame = self.xml:InitFrame(root, self)
	self.background_frame:Show(false)
	
	self.xml:InitAutoStaticGroup("w:"..root..":auto_static", self.background_frame)
	
	local tmp_tbl, def_font, def_color = nil, "letterica16", "255, 255, 255, 255"
	
	tmp_tbl = split_string(self.xml:ReadAttrib(root, "offset", "0,0"), ",")
	self.background_frame.offset = {x = tmp_tbl[1], y = tmp_tbl[2]}
	
	root = root..":info_list"
	self.info_list = self.xml:InitScrollView(root, self.background_frame)
	self.dcw = self.info_list:GetDesiredChildWidth()
end

function UIItemInfo:InitItemInfo()
	local item = self.item
	if not item then
	return end
	
	self.background_frame:Show(true)
	self.info_list:Clear()
	local sect = item:section()
	
	local root = "background_frame"
	local item_name = self.xml:InitStatic(root..":item_name", self.info_list)
	item_name:SetWidth(self.dcw)
	item_name:SetText(get_inv_name(sect))
	item_name:AdjustHeightToText()
	
	local weight_cost = self.xml:InitStatic(root..":weight_cost", self.info_list)
	weight_cost:SetWidth(self.dcw)
	
	local weight = self.xml:InitStatic(root..":weight_cost:weight", weight_cost)
	weight:SetText(string.format("%3.2f %s", item:weight(), game.translate_string("st_kg")))
	-- weight:AdjustHeightToText()

	local trade_partner = level.get_second_talker()
	local item_cost = trade_manager.get_trade_cost(item)
	if trade_partner and item_cost > 0 then
		local cost = self.xml:InitStatic(root..":weight_cost:cost", weight_cost)
		cost:SetText(string.format("%d %s", item_cost, game.translate_string("ui_st_money_regional")))
		-- cost:AdjustHeightToText()
		if ((parent_is_actor(item) and trade_partner:money() < item_cost) or (not parent_is_actor(item) and actor:money() < item_cost)) then
			cost:SetTextColor(red)
		end		
	end
	
	self:AttachDivider()
	
	self:AttachCustomInfo()
	
	text = get_inv_descr(sect)
	if text then
		local static = self.xml:InitStatic(root..":description", self.info_list)
		static:SetWidth(self.dcw)
		static:SetText(text)
		static:AdjustHeightToText()
	end
	self.info_list:SetHeight(self.info_list:GetPadSize().y + self.info_list:GetVertIndent())
	self.background_frame:SetWidth(self.info_list:GetWidth())
	self.background_frame:SetHeight(self.info_list:GetHeight())
	
	self.background_contrast:Show(true)
	local rect = Frect()
	self.background_frame:GetWndRect(rect)
	self.background_contrast:SetWndPos(rect.x1, rect.y1)
	self.background_contrast:SetWidth(rect.x2)
	self.background_contrast:SetHeight(rect.y2)
	
	if self.independent then
		local offset = ui_utils.GetOffset("center", self.background_frame, self)
		self.background_frame:SetWndPos(offset.x, offset.y)
		self.background_contrast:SetWndPos(offset.x, offset.y)
	end
	
	self.info_list:SetScrollPos(0)
	self.info_list:ForceScrollPos()
end

function UIItemInfo:SetShowTime()
	if self.independent then
		self:InitItemInfo()
	else
		self.show_time = time_global() + get_script_option_value("floating_show_delay") * 1000
	end
end

function UIItemInfo:UpdateWndPos()
	if not self.background_frame:IsShown() or self.independent then
	return end
	
	local pos = level.get_cursor_pos()
	pos.x = pos.x + self.background_frame.offset.x
	pos.y = pos.y + self.background_frame.offset.y
	local wnd_size = {x = self.background_frame:GetWidth(), y = self.background_frame:GetHeight()}
	local delta = {x = pos.x + wnd_size.x - UI_BASE_WIDTH, y = pos.y + wnd_size.y - UI_BASE_HEIGHT}
    if delta.x > 0 then
        pos.x = pos.x - delta.x
	end		
    if delta.y > 0 then
        pos.y = pos.y - delta.y
	end		
	self.background_frame:SetWndPos(pos.x, pos.y)
	self.background_contrast:SetWndPos(pos.x, pos.y)
end

function UIItemInfo:Update()
	CUIScriptWnd.Update(self)
	if self.show_time and time_global() >= self.show_time then
		self:InitItemInfo()
		self.show_time = nil
	end
	self:UpdateWndPos()
	self.info_list:SetScrollPos(0)
	self.info_list:ForceScrollPos()
end

function UIItemInfo:OnKeyboard(dik, keyboard_action)
	CUIScriptWnd.OnKeyboard(self, dik, keyboard_action)
	if keyboard_action == ui_events.WINDOW_KEY_PRESSED then
		self:DetachWnd()
		return true
	end
	return false
end
------------------------------------------ADDITIONAL WINDOWS-----------------------------------------------------------------------------------------------------------------

function UIItemInfo:AttachDivider()
	local divider = self.xml:InitStatic("divider", self.info_list)
	divider:SetWidth(self.dcw)
	return divider
end

function UIItemInfo:AttachParamsList()
	local params_list = self.xml:InitScrollView("params_list", self.info_list)
	params_list:SetWidth(self.dcw)
	return params_list
end

function UIItemInfo:AdjustParamsList(params_list)
	params_list:SetHeight(params_list:GetPadSize().y + params_list:GetVertIndent())
	params_list:SetScrollPos(0)
	params_list:ForceScrollPos()
end

function UIItemInfo:AttachHeader(text, params_list)
	local header = self.xml:InitStatic("header", params_list)
	header:SetWidth(params_list:GetDesiredChildWidth())
	header:SetText(game.translate_string(text))
	header:AdjustHeightToText()
end

function UIItemInfo:AttachParamItem(parent_list)
	local static = self.xml:InitStatic("param_item", parent_list)
	static:SetWidth(parent_list:GetDesiredChildWidth())
	static.icon = self.xml:InitStatic("param_item:icon", static)
	static.val = self.xml:InitStatic("param_item:val", static)
	static.name = self.xml:InitStatic("param_item:name", static)
	return static
end

function UIItemInfo:AttachCustomInfo()

	local function create_divider(show)
		if not show then
		return end
		self:AttachDivider()
	end

	create_divider(self:AttachConditionParams())
	
	if vest_plates.can_detach_plate(self.item) then
		create_divider(self:AttachPlateCondition())
	end	
	
	create_divider(self:AttachEffectparams())
	
	create_divider(self:AttachProtectionParams())
	
	create_divider(self:AttachArmorParams())
	
	create_divider(self:AttachAddonParams())
	
	create_divider(self:AttachBeltParams())
	
	create_divider(self:AttachRepairParams())
	
	if self.item:is_eatable_item() then
		create_divider(self:AttachEatableParams())
		create_divider(self:AttachBoosterParams())
		create_divider(self:AttachAnmUseParams())
	end
	if is_power_device(self.item) then
		create_divider(self:AttachPowerParams())
	end
	--if self.item:get_pda() then
	if is_pda_hackable(self.item) then
		create_divider(self:AttachPDAOwnerInfo())
	end	
	if self.item:is_weapon() then
		if self.item:is_knife() then
			create_divider(self:AttachKnifeParams())
		else
			create_divider(self:AttachWpnParams())
		end
	end
	if self.item:is_weapon_magazined() then
		create_divider(self:AttachLoadedAmmo())
		create_divider(self:AttachWpnAddons())
	end
	if loadout.is_module(self.item) then
		create_divider(self:AttachLoadoutSlots())
	end
	if self.item:get_weapon_ammo() then
		if self.item:get_weapon_ammo():is_magazine() then
			create_divider(self:AttachMagazineAmmo())
		else
			create_divider(self:AttachAmmoParams())
		end
	end
	if is_plate_carrier(self.item) then
		create_divider(self:AttachArmorPlates())
	end
	if loot_spawn_box.is_spawn_loot_box(self.item) then
		create_divider(self:AttachLootSpawnBoxInfo())
	end
	create_divider(self:AttachQuestTargetInfo())
end

------------------------------------------ITEM CONDITION WND-----------------------------------------------------------------------------------------------------------------
function UIItemInfo:AttachConditionParams()
	local condition = self.item:condition()
	
	local show_cond = condition < 1 or read_if_exists(sys_ini, "bool", self.item:section(), "use_condition", false)
	if not show_cond then
	return end
	
	local condition_params = self.xml:InitStatic("condition_params", self.info_list)
	condition_params:SetWidth(self.dcw)
	local condition_icon = self.xml:InitStatic("condition_params:icon", condition_params)
	condition_icon:SetColor(ui_utils.get_color_by_val(condition, 1, 0))
	local condition_progress = self.xml:InitProgressBar("condition_params:condition_progress", condition_params)
	condition_progress:SetProgressPos(condition)
	return true
end

------------------------------------------EFFECT PARAMS WND-----------------------------------------------------------------------------------------------------------------
local effect_params = {
	{param = "health_restore_speed", 		name = "ui_inv_health_boost", 		texture = "ui_hud_icon_health_warning"},
	{param = "power_restore_speed", 		name = "ui_inv_power", 				texture = "ui_hud_icon_power"},
	{param = "max_power_restore_speed", 	name = "ui_inv_max_power", 			texture = "ui_hud_icon_power"},
	{param = "satiety_restore_speed", 		name = "ui_inv_satiety", 			texture = "ui_hud_icon_eat"},
	{param = "radiation_restore_speed", 	name = "ui_inv_radiation", 			texture = "ui_hud_icon_radiation"},
	{param = "psy_health_restore_speed", 	name = "ui_inv_psy_health", 		texture = "ui_hud_icon_psycho"},
	{param = "alcohol_restore_speed", 		name = "ui_inv_alcohol", 			texture = "ui_hud_icon_alcohol"},
	{param = "wounds_heal_speed", 			name = "ui_inv_wounds_heal", 		texture = "ui_hud_icon_drop"},
	{param = "additional_sprint", 			name = "ui_inv_sprint", 			texture = "ui_hud_icon_sprint"},
	{param = "additional_jump", 			name = "ui_inv_jump", 				texture = "ui_hud_icon_jump"},
	{param = "additional_weight", 			name = "ui_inv_weight", 			texture = "ui_hud_icon_overweight"},
	{param = "power_loss", 					name = "st_power_loss", 			texture = "ui_hud_icon_power_loss"},
}
function UIItemInfo:AttachEffectparams()
	local inv_item = self.item:get_inventory_item()
	local val, sn, color
	local show = false
	
	local params_list = self:AttachParamsList()
	self:AttachHeader("st_effects_header", params_list)

	for k,v in ipairs(effect_params) do
		val = v.param == "power_loss" and inv_item.power_loss or inv_item:item_effect(k-1)
		if v.param == "power_loss" then
			if not (val < 0 and self.item:condition() > 0 or val > 0) then
				val = 0
			end
		end
		if val ~= 0 then
			--log3("~UIItemInfo:AttachEffectparams param %s | val %s", v.param, val)
			if k <= 8 then
				local for_rad = false--v.param == "radiation_restore_speed"
				local _k = for_rad and 1 or 100
				sn = game.translate_string(for_rad and "st_radiation_per_minute" or "st_percent_per_minute")
				val = val * 60 * _k
				if math.abs(val) < 0.1 then
					sn = game.translate_string(for_rad and "st_radiation_per_hour" or "st_percent_per_hour")
					val = val * 60
				end				
			else
			 	sn = game.translate_string("st_percent")
				val = val * 100
			end
			local static = self:AttachParamItem(params_list)
			static.icon:InitTexture(v.texture or "")
			color = val > 0 and green or red
			if plus_are_bad[v.param] then
				color = val > 0 and red or green
			end
			static:SetText(game.translate_string(v.name))
			static.val:SetText(string.format("%+.1f %s", val, sn))
			static.val:SetTextColor(color)
			static.icon:SetColor(color)
			show = true
		end
	end
	self:AdjustParamsList(params_list)
	if not show then
		params_list:Show(false)
	end
	return show
end

------------------------------------------PROTECTION PARAMS WND-----------------------------------------------------------------------------------------------------------------
local protection_params = {
	{param = "burn_immunity", 			name = "ui_inv_burn_protection", 			texture = "ui_hud_icon_burn_protection"},
	{param = "shock_immunity", 			name = "ui_inv_shock_protection", 			texture = "ui_hud_icon_shock_protection"},
	{param = "strike_immunity", 		name = "ui_inv_strike_protection", 			texture = "ui_hud_icon_strike_protection"},
	{param = "wound_immunity", 			name = "ui_inv_wound_protection", 			texture = "ui_hud_icon_wound_protection"},
	{param = "radiation_immunity", 		name = "ui_inv_radiation_protection", 		texture = "ui_hud_icon_radiation_protection"},
	{param = "telepatic_immunity", 		name = "ui_inv_telepatic_protection", 		texture = "ui_hud_icon_telepatic_protection"},
	{param = "chemical_burn_immunity", 	name = "ui_inv_chemical_burn_protection", 	texture = "ui_hud_icon_chemical_burn_protection"},
	{param = "explosion_immunity", 		name = "ui_inv_explosion_protection", 		texture = "ui_hud_icon_explosion_protection"},
	{param = "fire_wound_immunity", 	name = "ui_inv_fire_wound_protection", 		texture = "ui_hud_icon_fire_wound_protection"},
}
function UIItemInfo:AttachProtectionParams()
	local inv_item = self.item:get_inventory_item()
	local val, sn, color
	local show = false

	local params_list = self:AttachParamsList()
	self:AttachHeader("st_protection_header", params_list)

	for k,v in ipairs(protection_params) do
		val = inv_item:hit_type_protection(k-1)
		if val ~= 0 then
			sn = game.translate_string("st_percent")
			--log3("~self:AttachProtectionParams param %s | val %s", v.param, val)
			val = val * 100
			local static = self:AttachParamItem(params_list)
			static.icon:InitTexture(v.texture or "")
			color = val > 0 and green or red
			static:SetText(game.translate_string(v.name))
			static.val:SetText(string.format("%+.1f %s", val, sn))
			static.val:SetTextColor(color)
			static.icon:SetColor(color)			
			show = true
		end
	end
	self:AdjustParamsList(params_list)
	if not show then
		params_list:Show(false)
	end
	return show
end

------------------------------------------EATABLE PARAMS WND-----------------------------------------------------------------------------------------------------------------
local eatable_params = {
	{param = "health", 		name = "ui_inv_health", 		texture = "ui_hud_icon_health_warning"},
	{param = "power", 		name = "ui_inv_power", 			texture = "ui_hud_icon_power"},
	{param = "max_power", 	name = "ui_inv_max_power", 		texture = "ui_hud_icon_power"},
	{param = "satiety", 	name = "ui_inv_satiety", 		texture = "ui_hud_icon_eat"},
	{param = "radiation", 	name = "ui_inv_radiation", 		texture = "ui_hud_icon_radiation"},
	{param = "psyhealth", 	name = "ui_inv_psy_health", 	texture = "ui_hud_icon_psycho"},
	{param = "alcohol", 	name = "ui_inv_alcohol", 		texture = "ui_hud_icon_alcohol"},
	{param = "wounds_heal", name = "ui_inv_wounds_heal", 	texture = "ui_hud_icon_drop"},
	{param = "somnolence", 	name = "ui_inv_somnolence", 	texture = "ui_hud_icon_somnolence"},
}
function UIItemInfo:AttachEatableParams()
	local eatable = self.item:get_eatable_item()
	local val, sn, text, color
	local show = false

	local params_list = self:AttachParamsList()
	self:AttachHeader("st_influence_header", params_list)

	for k,v in ipairs(eatable_params) do
		val = v.param == "somnolence" and somnolence.get_influence(self.item) or eatable:influence(k-1)
		if val ~= 0 then
			sn = game.translate_string("st_percent")
			val = val * 100
			local static = self:AttachParamItem(params_list)
			static.icon:InitTexture(v.texture or "")
			color = val > 0 and green or red
			if plus_are_bad_eatable[v.param] then
				color = val > 0 and red or green
			end
			static:SetText(game.translate_string(v.name))
			static.val:SetText(string.format("%+.1f %s", val, sn))
			static.val:SetTextColor(color)
			static.icon:SetColor(color)
			show = true
		end
	end
	self:AdjustParamsList(params_list)
	if not show then
		params_list:Show(false)
	end
	return show
end

