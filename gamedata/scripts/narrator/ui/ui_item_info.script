------------------------------------------LOADED WEAPON AMMO WND-----------------------------------------------------------------------------------------------------------------
local pos_x
function UIItemInfo:AttachLoadedAmmo()
	local wpn = self.item:get_weapon_m()
	local show_ammo = self.item:get_ammo_in_magazine() > 0
	local show_mag = wpn:addon_attachable(addon_type.magazine) and wpn:is_addon_attached(addon_type.magazine)
	local show_ammo2 = self.item:get_ammo_in_magazine2() > 0
	
	if 
		not show_ammo and
		not show_mag and
		not show_ammo2 then
	return end

	pos_x = 0
	
	local main = self.xml:InitStatic("loaded_ammo", self.info_list)
	
	local ammo_s = {}
	for i=1,3 do
		ammo_s[i] = self.xml:InitStatic("loaded_ammo:ammo_icon", main)
		ammo_s[i]:Show(false)
	end

	if show_ammo then
		set_ammo_icon(ammo_s[1], get_cur_ammo_sect(self.item))
	end
	if show_mag then
		set_ammo_icon(ammo_s[2], wpn:get_addon_name(addon_type.magazine))
	end
	if show_ammo2 then
		set_ammo_icon(ammo_s[3], get_cur_ammo2_sect(self.item))
	end
	
	return true
end

function set_ammo_icon(icon, sect)
	local item_icon = ui_cell_item.UICellItemSimple(icon, sect)
	icon:SetWidth(item_icon:GetWidth())
	icon:Show(true)
	icon:SetWndPos(pos_x, icon:GetWndPos().y)
	pos_x = pos_x + icon:GetWidth()	
end

------------------------------------------LOADED WEAPON AMMO WND-----------------------------------------------------------------------------------------------------------------

function UIItemInfo:AttachMagazineAmmo()
	local ammo = self.item:get_weapon_ammo()
	if ammo.box_curr == 0 then
	return end
	
	local main = self.xml:InitStatic("loaded_ammo", self.info_list)
	local ammo_icon = self.xml:InitStatic("loaded_ammo:ammo_icon", main)
	
	pos_x = 0
	
	local sect = ammo:ammo_sect()
	set_ammo_icon(ammo_icon, sect)
	ammo_icon:SetText(game.translate_string(read_if_exists(sys_ini, "string", sect, "inv_name_short", get_inv_name(sect))))
	ammo_icon:SetTextPos(ammo_icon:GetWidth(), ammo_icon:GetHeight()/2)
	
	return true
end

------------------------------------------COMPATIBLE WEAPON ADDONS WND-----------------------------------------------------------------------------------------------------------------
local addon_type = {
	"silencer",
	"scope",
	"grenade_launcher",
	"laser",
	"flashlight",
	"sight",
	"extender",
	"magazine",
	"ammo",
	"grenade"
}
function UIItemInfo:AttachWpnAddons()
	if get_script_option_value("wpn_addon_ammo_wnd_separate") then
	return end
	
	local sect = self.item:section()

	local params_list = self:AttachParamsList()
	self:AttachHeader("st_compatible_ammo_addon", params_list)
	
	local function add_white_space()
		local white_space = CUIStatic()
		white_space:SetText(" ")
		white_space:AdjustHeightToText()
		white_space:SetWidth(params_list:GetDesiredChildWidth())
		params_list:AddWindow(white_space)
	end
	
	local function get_addon_str(i, sect)
		local addon_type = addon_type[i]
		if addon_type then
			local addon_str = read_if_exists(sys_ini, "string", sect, addon_type.."_name", nil)
			local addon_status = read_if_exists(sys_ini, "u32", sect, addon_type.."_status", 0)
			if i > 7 then
				addon_str = read_if_exists(sys_ini, "string", sect, addon_type.."_class", nil)
				addon_status = addon_str and 2 or 0
			end
			if addon_str and addon_status == 2 then				
				return addon_str
			end		
		end
		return false
	end	
	
	add_white_space()
	
	local show = false
	local addons = {}

	for i,addon in pairs(addon_type) do
		local addon_str = get_addon_str(i, sect)
		if addon_str then
			local static = self.xml:InitStatic("list_item", params_list)
			static:SetWidth(params_list:GetDesiredChildWidth())
			static:SetText(string.format("%s", game.translate_string("st_"..addon.."_header_name")))
			static:AdjustHeightToText()
			
			addons = split_string(addon_str, ",")
			for __,addon_sect in pairs(addons) do
				local static = self.xml:InitStatic("list_item", params_list)
				static:SetWidth(params_list:GetDesiredChildWidth())
				static:SetText(string.format("%s %s", game.translate_string("st_list_mark"), get_inv_name(addon_sect)))
				static:AdjustHeightToText()
				show = true
			end
			
			for _i=i+1, #addon_type do
				if get_addon_str(_i, sect) then
					add_white_space()
					break
				end
			end
		end
	end
	self:AdjustParamsList(params_list)
	if not show then
		params_list:Show(false)
	end
	return show
end

------------------------------------------ADDITIONAL LOADOUT SLOTS WND-----------------------------------------------------------------------------------------------------------------
local loadout_slots = {
		{param = "pistol_ammo", 	name = "ui_st_pistol_ammo", 	texture = "ui_hud_icon_pistol_ammo"},
		{param = "rifle_ammo", 		name = "ui_st_rifle_ammo", 		texture = "ui_hud_icon_rifle_ammo"},
		{param = "shotgun_ammo", 	name = "ui_st_shotgun_ammo", 	texture = "ui_hud_icon_shotgun_ammo"},
		{param = "heavy_ammo", 		name = "ui_st_heavy_ammo", 		texture = "ui_hud_icon_heavy_ammo"},
		{param = "grenade", 		name = "ui_st_grenade", 		texture = "ui_hud_icon_grenade"},
		{param = "medicine", 		name = "ui_st_medicine", 		texture = "ui_hud_icon_medicine"},
	}
function UIItemInfo:AttachLoadoutSlots()
	local params_list = self:AttachParamsList()
	local sect = self.item:section()
	local count, icon, text
	for k,v in ipairs(loadout_slots) do
		count = read_if_exists(sys_ini, "u32", sect, v.param, 0)
		--log3("~count %s", count)
		if count > 0 then
			local static = self:AttachParamItem(params_list)
			static.icon:InitTexture(v.texture)
			static.icon:SetColor(green)
			static:SetText(game.translate_string(v.name))
			static.val:SetText(count)
			static.val:SetTextColor(green)			
		end
	end
	self:AdjustParamsList(params_list)
	return true
end

-----------------------------------------------------AMMO PARAMS------------------------------------------------------------------------------------------------------------------------
local ammo_params = {
		{name = "k_dist", 			unit = "%", 					default = 0, is_int = false, invert = false},
		{name = "k_disp", 			unit = "%", 					default = 0, is_int = false, invert = true},
		{name = "k_hit", 			unit = "%", 					default = 0, is_int = false, invert = false},
		{name = "k_impulse", 		unit = "%", 					default = 0, is_int = false, invert = false},
		{name = "k_speed", 			unit = "%", 					default = 0, is_int = false, invert = false},
		{name = "k_air_resistance", unit = "%", 					default = 0, is_int = false, invert = false},
		{name = "impair", 			unit = "%", 					default = 0, is_int = false, invert = true},
		{name = "k_pierce", 		unit = "", 						default = 1, is_int = false, invert = false},		
		{name = "buck_shot", 		unit = "", 						default = 1, is_int = true, invert = false},		
		{name = "k_ap", 			unit = "st_armor_class", 		default = 0, is_int = true, invert = false},		
	}
function UIItemInfo:AttachAmmoParams()
	local show = false
	local params_list = self:AttachParamsList()
	self:AttachHeader("st_ammo_header", params_list)

	local sect = self.item:section()
	for k,v in ipairs(ammo_params) do
		local val = read_if_exists(sys_ini, "float", sect, v.name, v.default)
		if val ~= v.default then
			if v.unit == "%" then
				val = val * 100
			end
			local color = (v.unit ~= "%") and orange or val > 0 and green or red
			if v.invert then
				color = val > 0 and red or green
			end
			local text = string.format(v.is_int and "%.0f %s" or v.name == "k_pierce" and "%.1f %s" or "%+.1f %s", val, game.translate_string(v.unit))
			
			local static = self:AttachParamItem(params_list)
			static.icon:InitTexture(v.texture or "")
			static.icon:SetColor(green)
			static:SetText(game.translate_string("ui_st_"..v.name))
			static:SetTextPos(0,0)
			static.val:SetText(text)
			static.val:SetTextColor(color)
			
			show = true
		end
	end
	self:AdjustParamsList(params_list)
	if not show then
		params_list:Show(false)
	end
	return show
end

