function UIItemInfo:AttachWpnParams()
	if not read_if_exists(sys_ini, "bool", self.item:section(), "show_wpn_properties", true) then
	return end
	
	local name = "wpn_params"
	local main = self.xml:InitStatic(name, self.descr_list)
	
	local cap_dispersion 	= self.xml:InitStatic(name..":cap_dispersion", main)
	local cap_damage 		= self.xml:InitStatic(name..":cap_damage", main)
	local cap_speed 		= self.xml:InitStatic(name..":cap_speed", main)
	local cap_rpm 			= self.xml:InitStatic(name..":cap_rpm", main)
	local cap_range 		= self.xml:InitStatic(name..":cap_range", main)
	local cap_reliability 	= self.xml:InitStatic(name..":cap_reliability", main)

	local progress_dispersion 	= self.xml:InitProgressBar(name..":progress_dispersion", main)
	local progress_damage 		= self.xml:InitProgressBar(name..":progress_damage", main)
	local progress_speed 		= self.xml:InitProgressBar(name..":progress_speed", main)
	local progress_rpm 			= self.xml:InitProgressBar(name..":progress_rpm", main)
	local progress_range 		= self.xml:InitProgressBar(name..":progress_range", main)
	local progress_reliability 	= self.xml:InitProgressBar(name..":progress_reliability", main)
	
	local params = ui_wpn_params
	
	local text = string.format("%s (%.2f)", cap_dispersion:GetText(), params.GetDispersion(self.item))
	cap_dispersion:SetText(text)
	text = string.format("%s (%.1f)", cap_damage:GetText(), params.GetDamage(self.item))
	cap_damage:SetText(text)
	text = string.format("%s (%.0f)", cap_speed:GetText(), params.GetSpeed(self.item))
	cap_speed:SetText(text)
	text = string.format("%s (%.0f)", cap_rpm:GetText(), params.GetRPM(self.item))
	cap_rpm:SetText(text)	
	text = string.format("%s (%.0f)", cap_range:GetText(), params.GetRange(self.item))
	cap_range:SetText(text)	
	text = string.format("%s (%.0f)", cap_reliability:GetText(), params.GetReliability(self.item))
	cap_reliability:SetText(text)		
	
	progress_dispersion:SetProgressPos(params.GetDispersion(self.item))
	progress_damage:SetProgressPos(params.GetDamage(self.item))
	progress_speed:SetProgressPos(params.GetSpeed(self.item))
	progress_rpm:SetProgressPos(params.GetRPM(self.item))
	progress_range:SetProgressPos(params.GetRange(self.item))
	progress_reliability:SetProgressPos(params.GetReliability(self.item))
	
	return true
end

