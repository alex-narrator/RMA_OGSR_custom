local weapon_params = {
	["dispersion"] 	= { fmt = "%.2f", func = function(item) return ui_wpn_params.GetDispersion(item) end, },
	["damage"] 		= { fmt = "%.1f", func = function(item) return ui_wpn_params.GetDamage(item) end, },
	["speed"] 		= { fmt = "%.0f", func = function(item) return ui_wpn_params.GetSpeed(item) end, },
	["rpm"] 		= { fmt = "%.0f", func = function(item) return ui_wpn_params.GetRPM(item) end, },
	["range"] 		= { fmt = "%.0f", func = function(item) return ui_wpn_params.GetRange(item) end, },
	["reliability"] = { fmt = "%.0f", func = function(item) return ui_wpn_params.GetReliability(item) end, },
}
function UIItemInfo:AttachWpnParams()
	if not read_if_exists(sys_ini, "bool", self.item:section(), "show_wpn_properties", true) then
	return end
	
	local name = "wpn_params"
	local main = self.xml:InitStatic(name, self.info_list)
	
	for k,v in pairs(weapon_params) do
		local cap = self.xml:InitStatic(name..":cap_"..k, main)
		local val = self.xml:InitStatic(name..":val_"..k, main)
		local progress = self.xml:InitProgressBar(name..":progress_"..k, main)
		local value = v.func(self.item)
		val:SetText(string.format(v.fmt, value))
		progress:SetProgressPos(value)
	end
	
	return true
end

