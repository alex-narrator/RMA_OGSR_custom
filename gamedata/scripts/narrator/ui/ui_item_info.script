local boost_st = {}
function UIItemInfo:AttachBoosterParams()
	local eatable = self.item:get_eatable_item()
	local sect = self.item:section()
	local val, sn, text, color
	local show = false
	
	boost_st = {}
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(boost_st, "st_boost_header", params_list)

	for k,v in ipairs(boost_params) do
		if v.param == "boost_time" then
			val = read_if_exists(sys_ini, "float", sect, "boost_time", 0)
		else
			val = read_if_exists(sys_ini, "float", sect, BOOST_PARAMS[k], 0)
		end
		-- log3("item %s | boost val %s | boost type %s", self.item:name(), val, v.param)
		if val ~= 0 then
			if v.param == "boost_time" then
				sn = game.translate_string("st_time_minute")
			elseif k <= 8 or v.param == "boost_somnolence" then
				--log3("~name %s | val %s", v.param, val)
				local for_rad = false--v.param == "radiation_boost"
				local _k = for_rad and 1 or 100
				sn = game.translate_string(for_rad and "st_radiation_per_minute" or "st_percent_per_minute")
				val = val * 60 * _k
				if math.abs(val) < 0.1 then
					sn = game.translate_string(for_rad and "st_radiation_per_hour" or "st_percent_per_hour")
					val = val * 60
				end
			else
				sn = game.translate_string("st_percent")
				val = val * 100
			end
			boost_st[k] = self.xml:InitStatic("effect_item", params_list)
			boost_st[k]:SetWidth(params_list:GetDesiredChildWidth())
			boost_st[k].icon = self.xml:InitStatic("effect_item:icon", boost_st[k])
			boost_st[k].icon:InitTexture(v.texture or "")
			boost_st[k].val = self.xml:InitStatic("effect_item:val", boost_st[k])
			color = val > 0 and green or red
			if plus_are_bad[v.param] then
				color = val > 0 and red or green
			elseif v.param == "boost_time" then
				color = orange
			end
			boost_st[k]:SetText(game.translate_string(v.name))
			boost_st[k].val:SetText(v.param == "boost_time" and string.format("[%.f %s]", val, sn) or string.format("%+.1f %s", val, sn))
			boost_st[k].val:SetTextColor(color)
			boost_st[k].icon:SetColor(color)
			show = true
		end
	end
	params_list:SetHeight(params_list:GetPadSize().y)
	if not show then
		params_list:Show(false)
	end
	return show
end

function UIItemInfo:AttachAnmUseParams()
	local hud_sect = get_hud_sect(self.item)
	if not hud_sect then
	return end
	local anm_name = "anm_use"
	local anm_speed = read_if_exists(sys_ini, "float", hud_sect, anm_name.."_speed_k", 1)
	local anm_length = game.get_motion_length(hud_sect, anm_name, anm_speed)
	
	local use_delay = read_if_exists(sys_ini, "float", hud_sect, "use_delay", anm_length * 0.001)
	
	-- local static = self.xml:InitStatic("anm_use_time", self.descr_list)
	-- local text = string.format("%s %s %s%.1f %s", game.translate_string("st_list_mark"), game.translate_string("st_anm_use_time"), "%c[UI_orange]", use_delay, game.translate_string("st_time_second"))
	-- static:SetText(text)
	-- --static:AdjustHeightToText()
	-- static:AdjustWidthToText()
	local static = self.xml:InitStatic("effect_item", self.descr_list)
	static:SetWidth(self.descr_list:GetDesiredChildWidth())
	static.icon = self.xml:InitStatic("effect_item:icon", static)
	static.icon:InitTexture("time_limited_task_icon")
	static.val = self.xml:InitStatic("effect_item:val", static)
	static:SetText(game.translate_string("st_anm_use_time"))
	static.val:SetText(string.format("[%.f %s]", use_delay, game.translate_string("st_time_second")))
	static.val:SetTextColor(orange)
	static.icon:SetColor(orange)	
	return true
end

------------------------------------------ARMOR WND-------------------------------------------------------------------------------------------------------------------
local armor_params = {
	{bone = "bip01_head", 		name = "st_armor_head"},
	{bone = "jaw_1", 			name = "st_armor_jav"},
	{bone = "eye_left", 		name = "st_armor_eye"},
	{bone = "bip01_neck", 		name = "st_armor_neck"},
	{bone = "bip01_l_clavicle", name = "st_armor_clavicle"},
	{bone = "bip01_spine2", 	name = "st_armor_spine2"},
	{bone = "bip01_spine1", 	name = "st_armor_spine1"},
	{bone = "bip01_spine", 		name = "st_armor_spine"},
	{bone = "bip01_pelvis", 	name = "st_armor_pelvis"},
	{bone = "bip01_l_upperarm", name = "st_armor_upperarm"},
	{bone = "bip01_l_forearm", 	name = "st_armor_forearm"},
	{bone = "bip01_l_hand", 	name = "st_armor_hand"},
	{bone = "bip01_l_thigh", 	name = "st_armor_thigh"},
	{bone = "bip01_l_calf", 	name = "st_armor_calf"},
	{bone = "bip01_l_foot", 	name = "st_armor_foot"},
	{bone = "bip01_l_toe0", 	name = "st_armor_toe"},
}
local armor_st = {}
function UIItemInfo:AttachArmorParams()
	local bones_protect_sect = self.item:get_inventory_item().bone_protection_sect
	if not bones_protect_sect or self.item:condition() == 0 then
	return end
	
	local val, sn, text, tmp_tbl, bone_protect_str
	local show = false
	
	armor_st = {}
	local armored_bones = {}
	sn = game.translate_string("st_armor_class")
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(armor_st, "st_armor_header", params_list)

	for k,v in ipairs(armor_params) do
		bone_protect_str = read_if_exists(sys_ini, "string", bones_protect_sect, v.bone, nil)
		if bone_protect_str then
			tmp_tbl = split_string(bone_protect_str, ",")
			val = tonumber(tmp_tbl[2])
			if val > 0 then
				if not armored_bones[val] then
					armored_bones[val] = {}
				end
				table.insert(armored_bones[val], game.translate_string(v.name))
			end
		end
	end
	
	local divider
	for armor_class, armored_bone_names in pairs(armored_bones) do
		text = string.format("%s %s%.0f %s: %s", game.translate_string("st_list_mark"),"%c[UI_orange]", armor_class, sn, "%c[default]")
		for i=1, table.size(armored_bone_names) do
			divider = armored_bone_names[i+1] and ", " or ""
			text = text..armored_bone_names[i]..divider
		end
		--log3("~text %s", text)
		armor_st[armor_class] = CUIStatic()--self.xml:InitStatic(v.st_name, params_list)
		armor_st[armor_class]:SetWidth(params_list:GetDesiredChildWidth())
		armor_st[armor_class]:SetText(text)
		armor_st[armor_class]:SetTextComplexMode(true)		
		--armor_st[armor_class]:SetFont(GetFontCustom(font))
		armor_st[armor_class]:AdjustHeightToText()
		params_list:AddWindow(armor_st[armor_class])
		show = true		
	end
	
	--hit fraction
	val = read_if_exists(sys_ini, "float", bones_protect_sect, "hit_fraction", 0.1)
	if val > 0 then
		armor_st["hit_fraction"] = CUIStatic()--self.xml:InitStatic("hit_fraction", params_list)
		armor_st["hit_fraction"]:SetWidth(params_list:GetDesiredChildWidth())
		text = string.format("%s %s%.0f%s %s%s", game.translate_string("st_list_mark"),"%c[UI_orange]", val * 100, game.translate_string("st_percent"), "%c[default]", game.translate_string("st_armor_hit_fraction"))
		armor_st["hit_fraction"]:SetText(text)
		armor_st["hit_fraction"]:SetTextComplexMode(true)	
		--armor_st["hit_fraction"]:SetFont(GetFontCustom(font))
		armor_st["hit_fraction"]:AdjustHeightToText()
		params_list:AddWindow(armor_st["hit_fraction"])
	end
	--
	params_list:SetHeight(params_list:GetPadSize().y)
	if not show then
		params_list:Show(false)
	end
	return show
end

------------------------------------------BATTERY POWER WND-----------------------------------------------------------------------------------------------------------------
function UIItemInfo:AttachPowerParams()
	local bind_item = self.item:binded_object()

	local power_params = self.xml:InitScrollView("power_params", self.descr_list)--self.xml:InitStatic("power_params", self.descr_list)
	
	if not read_if_exists(sys_ini, "bool", self.item:section(), "condition_as_power", false) then
		local cap_power = self.xml:InitStatic("power_params:cap_power", power_params)
		cap_power:SetText(game.translate_string(read_if_exists(sys_ini, "string", self.item:section(), "power_level_name", "st_power_level")))
		cap_power:AdjustHeightToText()
		
		local power_progress = self.xml:InitProgressBar("power_params:progress_power", power_params)
		local power_level = bind_item:get_power_level()
		power_progress:SetProgressPos(power_level)
	end
	
	local cap_work_time = self.xml:InitStatic("power_params:cap_work_time", power_params)
	local worktime_text = string.format("%s %s %s", game.translate_string("st_work_time"), bind_item:get_work_time(), game.translate_string("st_time_hour"))
	if bind_item:power_source_detachable() then
		worktime_text = worktime_text..string.format(" [%s]", get_inv_name(bind_item:get_power_sect()))
	end
	cap_work_time:SetText(worktime_text)
	cap_work_time:AdjustHeightToText()
	
	power_params:SetHeight(power_params:GetPadSize().y)
	
	return true
end

