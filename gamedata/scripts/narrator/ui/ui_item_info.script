local protection_params = {
	{param = "burn_immunity", 			name = "ui_inv_burn_protection", 			texture = "ui_hud_icon_burn_protection"},
	{param = "shock_immunity", 			name = "ui_inv_shock_protection", 			texture = "ui_hud_icon_shock_protection"},
	{param = "strike_immunity", 		name = "ui_inv_strike_protection", 			texture = "ui_hud_icon_strike_protection"},
	{param = "wound_immunity", 			name = "ui_inv_wound_protection", 			texture = "ui_hud_icon_wound_protection"},
	{param = "radiation_immunity", 		name = "ui_inv_radiation_protection", 		texture = "ui_hud_icon_radiation_protection"},
	{param = "telepatic_immunity", 		name = "ui_inv_telepatic_protection", 		texture = "ui_hud_icon_telepatic_protection"},
	{param = "chemical_burn_immunity", 	name = "ui_inv_chemical_burn_protection", 	texture = "ui_hud_icon_chemical_burn_protection"},
	{param = "explosion_immunity", 		name = "ui_inv_explosion_protection", 		texture = "ui_hud_icon_explosion_protection"},
	{param = "fire_wound_immunity", 	name = "ui_inv_fire_wound_protection", 		texture = "ui_hud_icon_fire_wound_protection"},
}
local protection_st = {}
function UIItemInfo:AttachProtectionParams()
	local inv_item = self.item:get_inventory_item()
	local val, sn, color
	local show = false

	protection_st = {}
	local params_list = self.xml:InitScrollView("params_list", self.descr_list)
	self:AttachHeader(protection_st, "st_protection_header", params_list)

	for k,v in ipairs(protection_params) do
		val = inv_item:hit_type_protection(k-1)
		if val ~= 0 then
			sn = game.translate_string("st_percent")
			--log3("~self:AttachProtectionParams param %s | val %s", v.param, val)
			val = val * 100
			protection_st[k] = self.xml:InitStatic("effect_item", params_list)
			protection_st[k]:SetWidth(params_list:GetDesiredChildWidth())
			protection_st[k].icon = self.xml:InitStatic("effect_item:icon", protection_st[k])
			protection_st[k].icon:InitTexture(v.texture or "")
			protection_st[k].val = self.xml:InitStatic("effect_item:val", protection_st[k])			
			color = val > 0 and green or red
			protection_st[k]:SetText(game.translate_string(v.name))
			protection_st[k].val:SetText(string.format("%+.1f %s", val, sn))
			protection_st[k].val:SetTextColor(color)
			protection_st[k].icon:SetColor(color)			
			show = true
		end
	end
	params_list:SetHeight(params_list:GetPadSize().y)
	if not show then
		params_list:Show(false)
	end
	return show
end

