-- -*- mode: lua; coding: windows-1251-dos -*-

local gravity = level.physics_world():gravity()

function get_start_pos(item, owner)
	owner = owner or actor
	local res = actor and get_missile_throw_point(item) or nil
	if not res then
		res = vector()
		owner:g_fireParams(item, res, vector())
	end
	return res
end

local missile_states = {
	[global_flags.eThrowStart] = true,
	[global_flags.eReady] = true,
	[global_flags.eThrow] = true,
}
local weapon_states = {
	[global_flags.eFire] = true,
	[global_flags.eIdle] = true,
}
function get_speed(item)
	if not item then
	return end
	if item:is_zoomed() then
	return end
	local missile = item:get_missile()
	local wpn = item:get_weapon_mwg()
	local rg6 = get_clsid(item) == clsid.wpn_rg6_s
	
	local function show_for_weapon(item)
		return (rg6 or item:get_gl_mode()) and item:get_ammo_in_magazine() > 0 and weapon_states[item:get_hud_item_state()] and not actor_obj:is_actor_sprinting()
	end
	
	if missile and missile_states[item:get_hud_item_state()] then
		return missile.const_power and missile.const_force or missile.throw_force
	elseif wpn and show_for_weapon(item) then
		local param_sect = (wpn:addon_attachable(addon.launcher) and wpn:is_addon_attached(addon.launcher)) and wpn:get_addon_name(addon.launcher) or item:section()
		return sys_ini:r_float(param_sect, "grenade_vel")
	elseif rg6 and show_for_weapon(item) then
		return sys_ini:r_float(item:section(), "launch_speed")		
	end
end

function pos_on_trajectory(pos, speed, duration)
    --[[
        Projectile motion:
        x = v.x * t
        z = v.z * t
        y = (v.y * t) - (g * t^2 / 2)
    --]]
	local velocity = vector():set(device().cam_dir):mul(speed)	
    local t2_half = duration * duration * 0.5    
	local res = vector():set(
		pos.x + velocity.x * duration,
		pos.y + velocity.y * duration - gravity * t2_half,
		pos.z + velocity.z * duration
	)
    -- res.x = pos.x + velocity.x * duration
    -- res.y = pos.y + velocity.y * duration - gravity * t2_half
    -- res.z = pos.z + velocity.z * duration
	
    return res
end

function get_ground_y(pos)
    local vid = level.vertex_id(pos)
    if vid and vid < NEG_U32 then  -- valid vertex id
        local ground_pos = level.vertex_position(vid)
        if ground_pos then
            return ground_pos.y
        end
    end
    return nil
end

function get_ground_pos(pos)
    local vid = level.vertex_id(pos)
    if vid and vid < NEG_U32 then  -- valid vertex id
        return level.vertex_position(vid)
    end
    return nil
end

function get_missile_throw_point(item)
	local sect = item:section()
	local throw_bone = read_if_exists(sys_ini, "string", sect, "throw_point_bone", nil)
	if not throw_bone then
		return false
	end
	local throw_pos = read_if_exists(sys_ini, "vector", sect, "script_throw_point", vector())
	local missile = item:get_missile()
	if missile and missile.const_power then
		throw_pos = read_if_exists(sys_ini, "vector", sect, "script_throw_point_quick", throw_pos)
	end
	local dir = device().cam_dir
	local h = dir:getH() + throw_pos:getH()
	local p = dir:getP() + throw_pos:getP()
	local throw_vec = vector():setHP(h, p):normalize():mul(throw_pos:magnitude())
	local res = vector():set(device().cam_pos):add(throw_vec)	
	--log3("~res: %s %s %s", res.x, res.y, res.z)
	return res
end